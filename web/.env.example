# Frontend build-time config (Vite). Copy to web/.env.local for local dev, or
# set in your Vercel/Netlify project settings for deployment.

# Base URL of the deployed FastAPI backend. Defaults to http://localhost:8000
# when unset (see web/src/api.ts). In production point it at your Render URL:
# VITE_API_BASE=https://loyaltyforge-api.onrender.com
VITE_API_BASE=http://localhost:8000
