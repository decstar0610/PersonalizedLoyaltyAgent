# NVIDIA NIM API key — required for LLM inference and embeddings.
# Get one from https://build.nvidia.com/ and copy this file to .env
NVIDIA_API_KEY=your-nvidia-nim-api-key-here

# Data source (optional). Defaults to the 5 curated demo customers.
# Point at the large synthetic set without changing any code:
# CUSTOMERS_FILE=data/customers_large.json
CUSTOMERS_FILE=

# --- Deployment (Phase 0) ---
# Comma-separated exact origins allowed to call this API from the browser.
# Local dev defaults to the Vite ports; in production set this to your deployed
# frontend URL, e.g. ALLOWED_ORIGINS=https://loyaltyforge.vercel.app
# Use "*" only for a throwaway open test.
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173

# Rate limit for the paid /generate-journey endpoint (per client IP).
RATE_LIMIT_PER_WINDOW=20
RATE_LIMIT_WINDOW_SECONDS=600
